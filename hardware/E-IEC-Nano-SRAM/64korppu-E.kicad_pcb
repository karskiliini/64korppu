	;; ============================================================
	;; U1 - Arduino Nano 2x15 pin header (center)
	;; KiCad 2xN zigzag: odd pins left (x=0), even pins right (x=2.54)
	;; Left col (odd):  D1/TX(1), D0/RX(3), RST(5), GND(7), D2(9), D3(11),
	;;   D4(13), D5(15), D6(17), D7(19), D8(21), D9(23), D10(25), D11(27), D12(29)
	;; Right col (even): VIN(2), GND(4), RST(6), +5V(8), A7(10), A6(12),
	;;   A5(14), A4(16), A3(18), A2(20), A1(22), A0(24), AREF(26), 3V3(28), D13(30)
	;; ============================================================
	(footprint "Connector_PinHeader_2.54mm:PinHeader_2x15_P2.54mm_Vertical"
		(layer "F.Cu")
		(uuid "b000000b-0001-4000-8000-000000000001")
		(at 142 118)
		(property "Reference" "U1"
			(at 1.27 -2 0)
			(layer "F.SilkS")
			(uuid "b000000b-0001-4000-8000-000000000002")
			(effects
				(font
					(size 1 1)
					(thickness 0.15)
				)
			)
		)
		(property "Value" "Arduino_Nano"
			(at 1.27 37.6 0)
			(layer "F.Fab")
			(uuid "b000000b-0001-4000-8000-000000000003")
			(effects
				(font
					(size 1 1)
					(thickness 0.15)
				)
			)
		)
		;; Pin 1: D1/TX (left col, row 0) - unconnected
		(pad "1" thru_hole rect
			(at 0 0)
			(size 1.7 1.7)
			(drill 1.0)
			(layers "*.Cu" "*.Mask")
			(net 0 "")
			(uuid "b000000b-0001-4000-8000-000000000010")
		)
		;; Pin 2: VIN (right col, row 0) - unconnected
		(pad "2" thru_hole oval
			(at 2.54 0)
			(size 1.7 1.7)
			(drill 1.0)
			(layers "*.Cu" "*.Mask")
			(net 0 "")
			(uuid "b000000b-0001-4000-8000-000000000011")
		)
		;; Pin 3: D0/RX (left col, row 1) - unconnected
		(pad "3" thru_hole oval
			(at 0 2.54)
			(size 1.7 1.7)
			(drill 1.0)
			(layers "*.Cu" "*.Mask")
			(net 0 "")
			(uuid "b000000b-0001-4000-8000-000000000012")
		)
		;; Pin 4: GND (right col, row 1)
		(pad "4" thru_hole oval
			(at 2.54 2.54)
			(size 1.7 1.7)
			(drill 1.0)
